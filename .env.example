APP_ENV=development
DATABASE_URL=sqlite:///./data/jobs.db
EXPORT_DIR=./data/exports
INGEST_API_TOKEN=
ENABLED_PROVIDERS=mock
CRAWLER_ENABLED_PROVIDERS=topcv,itviec
PROVIDER_API_KEY=
PROVIDER_BASE_URL=
PROVIDER_API_VERSION=v1
TOPCV_API_KEY=
TOPCV_BASE_URL=
TOPCV_API_VERSION=v1
TOPCV_SEARCH_PATH=/jobs
TOPCV_APPLY_PATH=/applications
TOPCV_SEARCH_URL_TEMPLATE=https://www.topcv.vn/tim-viec-lam-{keyword_slug}
VIETNAMWORKS_API_KEY=
VIETNAMWORKS_BASE_URL=
VIETNAMWORKS_API_VERSION=v1
VIETNAMWORKS_SEARCH_PATH=/jobs
VIETNAMWORKS_APPLY_PATH=/applications
ITVIEC_SEARCH_URL_TEMPLATE=https://itviec.com/it-jobs/{keyword_slug}
REQUEST_TIMEOUT_SECONDS=20
CANDIDATE_STORAGE_DIR=./data/candidates
CANDIDATE_TASK_POLL_SECONDS=2
CANDIDATE_MATCH_LIMIT=50
QUEUE_BACKEND=database
NATS_URL=nats://nats:4222
CORE_API_BASE_URL=http://job-api:8000
CORE_API_INGEST_PATH=/api/v1/ingest/raw-jobs
CRAWL_BROWSER_TYPE=chromium
CRAWL_HEADLESS=true
CRAWL_VERBOSE=false
CRAWL_TEXT_MODE=false
CRAWL_PAGE_TIMEOUT_MS=45000
CRAWL_WAIT_FOR_TIMEOUT_MS=20000
CRAWL_DELAY_BEFORE_RETURN_HTML=1.0
